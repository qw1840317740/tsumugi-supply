# ============================================================
#  Environment variables — set these in Vercel Dashboard
#  (Settings → Environment Variables), NOT in this file.
# ============================================================

# Neon PostgreSQL connection string (from your Neon dashboard → Connect)
# Use the POOLED connection (with "-pooler" in the host)
DATABASE_URL=postgresql://user:password@host-pooler.region.aws.neon.tech/dbname?sslmode=require

# Random secret for signing JWT auth tokens
# Generate one: openssl rand -hex 32  (or any random 32+ char string)
JWT_SECRET=replace-with-a-random-secret
